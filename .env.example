# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...YOUR_ANON_KEY

# Server-only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhb...YOUR_SERVICE_ROLE_KEY

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Server-only — used as fallback when user has no custom key
ANTHROPIC_API_KEY=sk-ant-api03-...YOUR_KEY

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
