{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "next build",
  "devCommand": "next dev --port $PORT",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control",           "value": "no-store" },
        { "key": "X-Content-Type-Options",  "value": "nosniff"  },
        { "key": "X-Frame-Options",         "value": "DENY"     }
      ]
    }
  ]
}
